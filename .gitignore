# Git ignore file for the project
data/clean/*.csv
!data/clean/.gitkeep

# Secrets and environment variables
.env
.env.local
*.env

# Keep the safe example file
!.env.example

# Python virtual environments
.venv/
venv/
env/

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Test and coverage files
.pytest_cache/
.coverage
htmlcov/

# IDE settings
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Local logs
*.log

# Raw and generated data
data/raw/
data/backups/
data/output/
reports/generated/

# Keep folder placeholders if we add them
!data/raw/.gitkeep
!data/backups/.gitkeep
!data/output/.gitkeep
